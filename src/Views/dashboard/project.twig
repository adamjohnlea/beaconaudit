{% extends "layouts/base.twig" %}

{% block title %}{{ project is not null ? project.name.value : 'Unassigned URLs' }} - Beacon Audit{% endblock %}

{% block page_header %}
    <div class="flex items-center gap-3 text-sm">
        <div class="flex items-center gap-2">
            <a href="/" class="text-text-muted hover:text-text-secondary transition-colors">Dashboard</a>
            <span class="text-text-muted">/</span>
            <span class="text-text-primary font-medium">{{ project is not null ? project.name.value : 'Unassigned URLs' }}</span>
        </div>
        <div class="flex items-center gap-2 ml-2">
            <span class="inline-flex items-center h-5.5 px-2 rounded-md text-[11px] font-medium bg-accent-subtle text-text-secondary">{{ summary.totalUrls }} URLs</span>
            <span class="inline-flex items-center h-5.5 px-2 rounded-md text-[11px] font-medium bg-accent-subtle text-text-secondary">{{ summary.totalAudits }} audits</span>
            <span class="inline-flex items-center h-5.5 px-2 rounded-md text-[11px] font-medium {% if summary.averageScore >= 90 %}bg-badge-excellent-bg text-badge-excellent-text{% elseif summary.averageScore >= 70 %}bg-badge-good-bg text-badge-good-text{% else %}bg-badge-poor-bg text-badge-poor-text{% endif %}">Avg {{ summary.averageScore }}</span>
            {% if summary.urlsNeedingAttention > 0 %}
                <span class="inline-flex items-center h-5.5 px-2 rounded-md text-[11px] font-medium bg-badge-poor-bg text-badge-poor-text">{{ summary.urlsNeedingAttention }} need attention</span>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block page_actions %}
    {% if project is not null %}
        <form method="post" action="/projects/{{ project.id }}/subscribe" class="inline">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            {% if isSubscribed is defined and isSubscribed %}
                <button type="submit" class="inline-flex items-center h-8 px-3 border border-border text-text-secondary text-[13px] font-medium rounded-lg hover:text-text-primary hover:border-text-muted transition-colors duration-150">
                    <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path></svg>
                    Unsubscribe
                </button>
            {% else %}
                <button type="submit" class="inline-flex items-center h-8 px-3 border border-border text-text-secondary text-[13px] font-medium rounded-lg hover:text-text-primary hover:border-text-muted transition-colors duration-150">
                    <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    Subscribe
                </button>
            {% endif %}
        </form>
        <a href="/projects/{{ project.id }}/report" class="inline-flex items-center h-8 px-3 border border-border text-text-secondary text-[13px] font-medium rounded-lg hover:text-text-primary hover:border-text-muted transition-colors duration-150">
            <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            PDF Report
        </a>
    {% endif %}
    {% if currentUser is defined and currentUser is not null and currentUser.admin %}
        <a href="/urls/create" class="inline-flex items-center h-8 px-3 bg-accent text-white text-[13px] font-medium rounded-lg hover:bg-accent-hover transition-colors duration-150">Add URL</a>
    {% endif %}
{% endblock %}

{% block content %}
{% if project is not null and project.description is not null %}
    <p class="text-sm text-text-secondary mb-6">{{ project.description }}</p>
{% endif %}

{# URL Table #}
<div class="bg-surface-raised border border-border rounded-xl">
    <div class="px-5 py-4 border-b border-border-subtle">
        <h2 class="text-sm font-semibold text-text-primary">Monitored URLs</h2>
    </div>

    {% if urlSummaries is empty %}
        <div class="p-10 text-center text-sm text-text-muted">
            No URLs in this project yet.
        </div>
    {% else %}
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-border-subtle">
                        <th class="px-5 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">URL</th>
                        <th class="px-5 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Latest Score</th>
                        <th class="px-5 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Audits</th>
                        <th class="px-5 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Frequency</th>
                        <th class="px-5 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Status</th>
                        <th class="px-5 py-3 text-right text-xs font-medium text-text-muted uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for urlSummary in urlSummaries %}
                    <tr class="border-b border-border-subtle last:border-0 hover:bg-accent-subtle transition-colors duration-100">
                        <td class="px-5 py-2.5">
                            <span class="text-sm font-medium text-text-primary">{{ urlSummary.name }}</span>
                            <a href="{{ urlSummary.address }}" target="_blank" rel="noopener noreferrer" class="text-xs text-text-muted hover:text-text-secondary underline underline-offset-2 decoration-stone-300 hover:decoration-stone-400 transition-colors ml-1.5">{{ urlSummary.address }}</a>
                        </td>
                        <td class="px-5 py-2.5">
                            {% if urlSummary.latestDesktopScore is null and urlSummary.latestMobileScore is null %}
                                <span class="text-sm text-text-muted">&mdash;</span>
                            {% else %}
                                <div class="flex items-center gap-1.5">
                                    {% if urlSummary.latestDesktopScore is not null %}
                                        {% set ds = urlSummary.latestDesktopScore %}
                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs font-medium
                                            {% if ds >= 90 %}bg-badge-excellent-bg text-badge-excellent-text
                                            {% elseif ds >= 70 %}bg-badge-good-bg text-badge-good-text
                                            {% elseif ds >= 50 %}bg-badge-average-bg text-badge-average-text
                                            {% else %}bg-badge-poor-bg text-badge-poor-text{% endif %}">
                                            <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 16 16" fill="currentColor"><path d="M1 3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H8.5v1H10a.5.5 0 0 1 0 1H6a.5.5 0 0 1 0-1h1.5v-1H2a1 1 0 0 1-1-1V3zm13 0H2v8h12V3z"/></svg>
                                            {{ ds }}
                                        </span>
                                    {% endif %}
                                    {% if urlSummary.latestMobileScore is not null %}
                                        {% set ms = urlSummary.latestMobileScore %}
                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs font-medium
                                            {% if ms >= 90 %}bg-badge-excellent-bg text-badge-excellent-text
                                            {% elseif ms >= 70 %}bg-badge-good-bg text-badge-good-text
                                            {% elseif ms >= 50 %}bg-badge-average-bg text-badge-average-text
                                            {% else %}bg-badge-poor-bg text-badge-poor-text{% endif %}">
                                            <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 16 16" fill="currentColor"><path d="M11 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h6zM5 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H5zm3 13a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/></svg>
                                            {{ ms }}
                                        </span>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </td>
                        <td class="px-5 py-2.5 text-sm text-text-secondary">
                            {{ urlSummary.totalAudits }}
                        </td>
                        <td class="px-5 py-2.5 text-sm text-text-secondary">
                            {{ urlSummary.frequency }}
                        </td>
                        <td class="px-5 py-2.5">
                            {% if urlSummary.enabled %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-badge-excellent-bg text-badge-excellent-text">Active</span>
                            {% else %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-accent-subtle text-text-secondary">Paused</span>
                            {% endif %}
                        </td>
                        <td class="px-5 py-2.5 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="/dashboard/{{ urlSummary.urlId }}" class="inline-flex items-center h-7 px-2.5 text-[12px] font-medium rounded-md border border-border text-text-secondary hover:text-text-primary hover:border-text-muted transition-colors duration-150">View</a>
                                {% if currentUser is defined and currentUser is not null and currentUser.admin %}
                                <form method="post" action="/dashboard/{{ urlSummary.urlId }}/run-audit" class="inline" onsubmit="this.querySelector('button').disabled=true;this.querySelector('button').textContent='Running...'">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                    <button type="submit" class="inline-flex items-center h-7 px-2.5 text-[12px] font-medium rounded-md bg-accent text-white hover:bg-accent-hover transition-colors duration-150 disabled:opacity-50">Audit</button>
                                </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}

{% extends "layouts/base.twig" %}

{% block title %}URLs - Beacon Audit{% endblock %}

{% block page_header %}
    <h1 class="text-lg font-semibold text-text-primary tracking-tight">Monitored URLs</h1>
{% endblock %}

{% block page_actions %}
    <div class="flex items-center gap-2">
        <a href="/urls/bulk-import" class="inline-flex items-center h-8 px-3 border border-border text-[13px] font-medium text-text-secondary rounded-lg hover:text-text-primary hover:border-text-muted transition-colors duration-150">Bulk Import</a>
        <a href="/urls/create" class="inline-flex items-center h-8 px-3 bg-accent text-white text-[13px] font-medium rounded-lg hover:bg-accent-hover transition-colors duration-150">Add URL</a>
    </div>
{% endblock %}

{% block content %}
<div>
    <form method="GET" action="/urls" class="flex items-center gap-2 mb-4">
        <input type="text" name="search" value="{{ search }}" placeholder="Search by name or URL…"
               class="h-8 w-72 text-sm">
        <button type="submit" class="inline-flex items-center h-8 px-3 bg-accent text-white text-[13px] font-medium rounded-lg hover:bg-accent-hover transition-colors duration-150">Search</button>
        {% if search %}
            <a href="/urls" class="inline-flex items-center h-8 px-3 border border-border text-[13px] font-medium text-text-secondary rounded-lg hover:text-text-primary hover:border-text-muted transition-colors duration-150">Clear</a>
        {% endif %}
    </form>

    {% if urls is empty %}
        <div class="border border-border rounded-xl p-12 text-center">
            <div class="text-sm text-text-muted">
                {% if search %}No URLs found matching "{{ search }}".{% else %}No URLs being monitored yet. Add one to get started.{% endif %}
            </div>
        </div>
    {% else %}
        <div class="bg-surface-raised border border-border rounded-xl">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-border-subtle">
                            <th class="px-5 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Name</th>
                            <th class="px-5 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">URL</th>
                            <th class="px-5 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Frequency</th>
                            <th class="px-5 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Latest Score</th>
                            <th class="px-5 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Status</th>
                            <th class="px-5 py-3 text-right text-xs font-medium text-text-muted uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for url in urls %}
                        <tr class="border-b border-border-subtle last:border-0 hover:bg-accent-subtle transition-colors duration-100">
                            <td class="px-5 py-3.5 text-sm font-medium text-text-primary">{{ url.name }}</td>
                            <td class="px-5 py-3.5 text-sm text-text-secondary">{{ url.url.value }}</td>
                            <td class="px-5 py-3.5 text-sm text-text-secondary">{{ url.auditFrequency.label }}</td>
                            <td class="px-5 py-3.5">
                                {% set scores = latestScores[url.id] ?? {} %}
                                {% if scores is empty %}
                                    <span class="text-xs text-text-muted">No audits yet</span>
                                {% else %}
                                    <div class="flex items-center gap-1.5">
                                        {% if scores.desktop is defined %}
                                            {% set ds = scores.desktop %}
                                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs font-medium
                                                {% if ds >= 90 %}bg-badge-excellent-bg text-badge-excellent-text
                                                {% elseif ds >= 70 %}bg-badge-good-bg text-badge-good-text
                                                {% elseif ds >= 50 %}bg-badge-average-bg text-badge-average-text
                                                {% else %}bg-badge-poor-bg text-badge-poor-text{% endif %}">
                                                <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 16 16" fill="currentColor"><path d="M1 3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H8.5v1H10a.5.5 0 0 1 0 1H6a.5.5 0 0 1 0-1h1.5v-1H2a1 1 0 0 1-1-1V3zm13 0H2v8h12V3z"/></svg>
                                                {{ ds }}
                                            </span>
                                        {% endif %}
                                        {% if scores.mobile is defined %}
                                            {% set ms = scores.mobile %}
                                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs font-medium
                                                {% if ms >= 90 %}bg-badge-excellent-bg text-badge-excellent-text
                                                {% elseif ms >= 70 %}bg-badge-good-bg text-badge-good-text
                                                {% elseif ms >= 50 %}bg-badge-average-bg text-badge-average-text
                                                {% else %}bg-badge-poor-bg text-badge-poor-text{% endif %}">
                                                <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 16 16" fill="currentColor"><path d="M11 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h6zM5 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H5zm3 13a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/></svg>
                                                {{ ms }}
                                            </span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </td>
                            <td class="px-5 py-3.5">
                                {% if url.enabled %}
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-badge-excellent-bg text-badge-excellent-text">Active</span>
                                {% else %}
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-accent-subtle text-text-secondary">Disabled</span>
                                {% endif %}
                            </td>
                            <td class="px-5 py-3.5 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="/urls/{{ url.id }}/edit" class="inline-flex items-center h-7 px-2.5 text-[12px] font-medium rounded-md border border-border text-text-secondary hover:text-text-primary hover:border-text-muted transition-colors duration-150">Edit</a>
                                    <form method="POST" action="/urls/{{ url.id }}/delete" class="inline" onsubmit="return confirm('Are you sure you want to delete this URL?')">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                        <button type="submit" class="inline-flex items-center h-7 px-2.5 text-[12px] font-medium rounded-md border border-red-200 text-danger hover:bg-error-bg transition-colors duration-150">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {% if totalPages > 1 %}
        <div class="flex items-center justify-between text-sm text-text-muted mt-4">
            <span>Showing {{ urls|length }} of {{ total }} URLs</span>
            <div class="flex items-center gap-1">
                {% if currentPage > 1 %}
                    <a href="/urls?page={{ currentPage - 1 }}{% if search %}&search={{ search|url_encode }}{% endif %}"
                       class="inline-flex items-center h-7 px-2.5 text-[12px] font-medium rounded-md border border-border text-text-secondary hover:text-text-primary hover:border-text-muted transition-colors duration-150">← Prev</a>
                {% endif %}

                {% for p in 1..totalPages %}
                    {% if p == currentPage %}
                        <span class="inline-flex items-center h-7 px-2.5 text-[12px] font-medium rounded-md bg-accent text-white">{{ p }}</span>
                    {% elseif p == 1 or p == totalPages or (p >= currentPage - 2 and p <= currentPage + 2) %}
                        <a href="/urls?page={{ p }}{% if search %}&search={{ search|url_encode }}{% endif %}"
                           class="inline-flex items-center h-7 px-2.5 text-[12px] font-medium rounded-md border border-border text-text-secondary hover:text-text-primary hover:border-text-muted transition-colors duration-150">{{ p }}</a>
                    {% elseif p == currentPage - 3 or p == currentPage + 3 %}
                        <span class="px-1 text-text-muted">…</span>
                    {% endif %}
                {% endfor %}

                {% if currentPage < totalPages %}
                    <a href="/urls?page={{ currentPage + 1 }}{% if search %}&search={{ search|url_encode }}{% endif %}"
                       class="inline-flex items-center h-7 px-2.5 text-[12px] font-medium rounded-md border border-border text-text-secondary hover:text-text-primary hover:border-text-muted transition-colors duration-150">Next →</a>
                {% endif %}
            </div>
        </div>
        {% else %}
        <div class="text-sm text-text-muted mt-4">Showing {{ urls|length }} of {{ total }} URLs</div>
        {% endif %}
    {% endif %}
</div>
{% endblock %}

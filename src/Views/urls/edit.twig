{% extends "layouts/base.twig" %}

{% block title %}Edit URL - Beacon Audit{% endblock %}

{% block page_header %}
    <div class="flex items-center gap-2 text-sm">
        <a href="/urls" class="text-text-muted hover:text-text-secondary transition-colors">URLs</a>
        <span class="text-text-muted">/</span>
        <span class="text-text-primary font-medium">Edit</span>
    </div>
{% endblock %}

{% block content %}
<div class="max-w-lg">
    {% if error is defined %}
        <div class="bg-error-bg border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">
            {{ error }}
        </div>
    {% endif %}

    <form method="POST" action="/urls/{{ url.id }}/update" class="space-y-5">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

        <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">URL</label>
            <p class="text-sm text-text-secondary">{{ url.url.value }}</p>
        </div>

        <div>
            <label for="name" class="block text-sm font-medium text-text-primary mb-1.5">Name</label>
            <input type="text" name="name" id="name" required
                   value="{{ url.name }}">
        </div>

        <div>
            <label for="audit_frequency" class="block text-sm font-medium text-text-primary mb-1.5">Audit Frequency</label>
            <select name="audit_frequency" id="audit_frequency">
                {% for freq in frequencies %}
                    <option value="{{ freq.value }}" {{ url.auditFrequency.value == freq.value ? 'selected' : '' }}>{{ freq.label }}</option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label for="audit_strategy" class="block text-sm font-medium text-text-primary mb-1.5">Audit Strategy</label>
            <select name="audit_strategy" id="audit_strategy">
                {% for strategy in auditStrategies %}
                    <option value="{{ strategy.value }}" {{ url.auditStrategy.value == strategy.value ? 'selected' : '' }}>{{ strategy.label }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="flex items-center gap-2">
            <input type="hidden" name="enabled" value="0">
            <input type="checkbox" name="enabled" id="enabled" value="1"
                   {{ url.enabled ? 'checked' : '' }}
                   class="h-4 w-4 rounded border-border text-accent focus:ring-text-secondary">
            <label for="enabled" class="text-sm text-text-primary">Include in scheduled audits</label>
        </div>

        <div>
            <label for="project_id" class="block text-sm font-medium text-text-primary mb-1.5">Project (optional)</label>
            <select name="project_id" id="project_id">
                <option value="">No project</option>
                {% for project in projects %}
                    <option value="{{ project.id }}" {{ url.projectId == project.id ? 'selected' : '' }}>{{ project.name.value }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="border border-border rounded-lg p-4 space-y-4" x-data="{ alertsEnabled: {{ url.alertsEnabled ? 'true' : 'false' }} }">
            <div class="flex items-center gap-2">
                <input type="hidden" name="alerts_enabled" value="0">
                <input type="checkbox" name="alerts_enabled" id="alerts_enabled" value="1"
                       {{ url.alertsEnabled ? 'checked' : '' }}
                       x-model="alertsEnabled"
                       class="h-4 w-4 rounded border-border text-accent focus:ring-text-secondary">
                <label for="alerts_enabled" class="text-sm font-medium text-text-primary">Enable score alerts</label>
            </div>
            <p class="text-xs text-text-muted -mt-1">Send an email alert to project subscribers when a threshold is breached.</p>

            <div x-show="alertsEnabled" x-cloak class="space-y-4 pt-1">
                <div>
                    <label for="alert_threshold_score" class="block text-sm font-medium text-text-primary mb-1.5">
                        Alert when score falls at or below
                    </label>
                    <div class="flex items-center gap-2">
                        <input type="number" name="alert_threshold_score" id="alert_threshold_score"
                               min="0" max="100"
                               value="{{ url.alertThresholdScore }}"
                               placeholder="e.g. 70"
                               class="w-28">
                        <span class="text-sm text-text-muted">/ 100</span>
                    </div>
                    <p class="text-xs text-text-muted mt-1">Leave blank to disable this check.</p>
                </div>

                <div>
                    <label for="alert_threshold_drop" class="block text-sm font-medium text-text-primary mb-1.5">
                        Alert when score drops by
                    </label>
                    <div class="flex items-center gap-2">
                        <input type="number" name="alert_threshold_drop" id="alert_threshold_drop"
                               min="1" max="100"
                               value="{{ url.alertThresholdDrop }}"
                               placeholder="e.g. 10"
                               class="w-28">
                        <span class="text-sm text-text-muted">points or more</span>
                    </div>
                    <p class="text-xs text-text-muted mt-1">Leave blank to disable this check.</p>
                </div>
            </div>
        </div>

        <div class="flex justify-end gap-3 pt-2">
            <a href="/urls" class="inline-flex items-center h-9 px-4 border border-border rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:border-text-muted transition-colors duration-150">Cancel</a>
            <button type="submit" class="inline-flex items-center h-9 px-4 bg-accent text-white rounded-lg text-sm font-medium hover:bg-accent-hover transition-colors duration-150">Update URL</button>
        </div>
    </form>
</div>
{% endblock %}
